{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/resp-bench/schemas/valkey-server-benchmark/matrix-config.schema.json",
  "title": "Valkey Server Benchmark — Matrix Configuration",
  "description": "Configuration for sweeping a scale multiplier across experiment runs. Base set_clients and get_clients are multiplied by each scale value. Supports both local server binaries and remote server endpoints.",
  "type": "object",
  "required": ["description", "experiment_template", "dimensions"],
  "properties": {
    "description": {
      "type": "string",
      "description": "Human-readable description of this matrix sweep"
    },
    "experiment_template": {
      "type": "object",
      "description": "Base experiment configuration. set_clients and get_clients are base values that get multiplied by each scale factor.",
      "required": [
        "iterations", "servers", "amz_valkey_benchmark_binary",
        "output_directory", "experiment_duration_seconds", "port", "keyspace", "clients"
      ],
      "properties": {
        "description": { "type": "string" },
        "iterations": { "type": "integer", "minimum": 1 },
        "servers": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "local-server-info": {
                "type": "object",
                "required": ["binary"],
                "properties": {
                  "binary": { "type": "string" },
                  "args": { "type": "array", "items": { "type": "string" } }
                }
              },
              "remote-server-info": {
                "type": "object",
                "required": ["endpoint"],
                "properties": {
                  "endpoint": { "type": "string" },
                  "port": { "type": "integer", "default": 6379 }
                }
              }
            },
            "oneOf": [
              { "required": ["local-server-info"] },
              { "required": ["remote-server-info"] }
            ]
          }
        },
        "servers_directory": {
          "type": "string",
          "description": "Required when using local-server-info servers"
        },
        "amz_valkey_benchmark_binary": { "type": "string" },
        "output_directory": { "type": "string" },
        "experiment_duration_seconds": { "type": "integer", "minimum": 1 },
        "warmup_skip_seconds": { "type": "number", "minimum": 0, "default": 5 },
        "port": { "type": "integer", "default": 6379 },
        "keyspace": {
          "type": "object", "required": ["key_count", "data_size_bytes"],
          "properties": {
            "key_count": { "type": "integer", "minimum": 1 },
            "data_size_bytes": { "type": "integer", "minimum": 1 },
            "seed": { "type": "integer" }
          }
        },
        "clients": {
          "type": "object",
          "description": "Base client connection counts. Multiplied by each scale factor. set_clients and get_clients are total TCP connections at scale=1.",
          "required": ["max_connections_per_benchmark_process", "set_clients", "get_clients"],
          "properties": {
            "max_connections_per_benchmark_process": {
              "type": "integer", "minimum": 1,
              "description": "Max connections per amz_valkey-benchmark process"
            },
            "set_clients": {
              "type": "integer", "minimum": 0,
              "description": "Base SET connections (multiplied by scale)"
            },
            "get_clients": {
              "type": "integer", "minimum": 0,
              "description": "Base GET connections (multiplied by scale)"
            }
          }
        },
        "numa": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "server_node": { "type": "integer", "minimum": 0 },
            "benchmark_node": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "dimensions": {
      "type": "object",
      "description": "Sweep dimensions.",
      "required": ["scale"],
      "properties": {
        "scale": {
          "type": "array",
          "description": "Array of scale multipliers. For each value, set_clients and get_clients from the template are multiplied by the scale factor.",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    }
  },
  "additionalProperties": false
}
